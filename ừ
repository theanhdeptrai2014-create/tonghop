const doubleTapTimes={s1:0,s2:0};
function checkDoubleTap(k){
  const now=Date.now();
  if(now-doubleTapTimes[k]<280){
    // trigger skill
    if(k==='s1')triggerSkill(p1,p2);
    if(k==='s2')triggerSkill(p2,p1);
    doubleTapTimes[k]=0;
  } else {
    doubleTapTimes[k]=now;
  }
}

