-- ========== KEY VALIDATION ==========
local function validateKey(key)
    if key == INFINITE_KEY then
        return "infinite", "VÔ HẠN....acmin"
    elseif KEYS_2_DAYS[key] then
        return "2days", "2 NGÀY"
    elseif KEYS_1_DAY[key] then
        return "1day", "1 NGÀY"
    end
    return nil, nil
end

