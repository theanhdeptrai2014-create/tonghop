-- Submit key
submitBtn.MouseButton1Click:Connect(function()
    local key = keyInput.Text
    
    if key == "" then
        statusLabel.Text = "⚠️ Vui lòng nhập key!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
        return
    end
    
    local keyType, durationText = validateKey(key)
    
    if keyType then
        statusLabel.Text = "✅ KEY HỢP LỆ! (" .. durationText .. ")"
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        
        TweenService:Create(keyFrame, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(40, 80, 40)}):Play()
        
        task.wait(0.8)
        
        -- Hide key frame, show main hub
        TweenService:Create(keyFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back), {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0)
        }):Play()
        
        task.wait(0.5)
        keyFrame.Visible = false
        
        -- Show main hub
        mainHub.Visible = true
        toggleBtn.Visible = true
        
        TweenService:Create(mainHub, TweenInfo.new(0.5, Enum.EasingStyle.Back), {
            Size = UDim2.new(0, 550, 0, 400)
        }):Play()
    else
        statusLabel.Text = "❌ KEY KHÔNG HỢP LỆ!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        
        local originalPos = keyFrame.Position
        TweenService:Create(keyFrame, TweenInfo.new(0.05), {Position = UDim2.new(0.5, -235, 0.5, -175)}):Play()
        task.wait(0.05)
        TweenService:Create(keyFrame, TweenInfo.new(0.05), {Position = UDim2.new(0.5, -215, 0.5, -175)}):Play()
        task.wait(0.05)
        TweenService:Create(keyFrame, TweenInfo.new(0.05), {Position = originalPos}):Play()
    end
end)

