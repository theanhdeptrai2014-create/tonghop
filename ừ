function drawMapThumb(cx,m,tw,th){
  cx.fillStyle=m.bg;cx.fillRect(0,0,tw,th);
  cx.fillStyle='#445';
  m.plats.forEach(pl=>{
    const x=pl.x/100*tw,y=pl.y/100*th,w=pl.w/100*tw,h=Math.max(2,pl.h/100*th);
    cx.fillStyle=pl.t==='lava'?'#f60':pl.t==='ice'?'#adf':pl.t==='bounce'?'#f0f':'#4a6';
    cx.fillRect(x,y,w,h);
  });
  (m.spikes||[]).forEach(sp=>{
    cx.fillStyle='#f44';
    cx.fillRect(sp.x/100*tw,sp.y/100*th,sp.w/100*tw,4);
  });
}
function randomMap(){
  curMap=Math.floor(Math.random()*MAPS.length);
  buildMapGrid();
}

