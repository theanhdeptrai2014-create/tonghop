  document.getElementById('p2weapon').style.color=wc2.color;
}

// ============================================================
// AI (smarter)
// ============================================================
function aiTick(ai,target){
  if(ai.dead||ai.stunTimer)return;
  const ai_=ai.aiState;
  ai_.timer++;ai_.jumpCd--;
  const cx=ai.x+ai.w/2,cy=ai.y+ai.h/2;
  const tx=target.x+target.w/2,ty=target.y+target.h/2;
  const dx=tx-cx,dy=ty-cy,dist=Math.abs(dx);
  ai.facing=dx>0?1:-1;

  // skill
  if(ai.skillCooldown<=0&&dist<120&&Math.random()<0.012)triggerSkill(ai,target);

  // attack
  const wt=WPN[ai.weapon];
  if(ai.attackCooldown<=0){
    if((ai.weapon==='gun'||ai.weapon==='shuriken')&&dist<350&&Math.abs(dy)<80){doAttack(ai,target);}
    else if(dist<wt.range+10&&Math.abs(dy)<55){doAttack(ai,target);}
  }

  // move
  const ideal=wt.range*0.7;
  if(dist>ideal+20){ai.vx=dx>0?SPEED*0.95:-SPEED*0.95;}
  else if(dist<ideal-20){ai.vx=dx>0?-SPEED*0.6:SPEED*0.6;}
  else ai.vx*=0.8;

  // dodge randomly
  if(Math.random()<0.008)ai.vx*=-1.5;

  // jump to reach target
  if(ai_.jumpCd<=0&&ai.onGround){
    const shouldJump=ty<cy-30||Math.random()<0.018;
    if(shouldJump){ai.vy=JUMP_V;ai.onGround=false;ai_.jumpCd=45;spawnJumpDust(ai);}
  }
  // double jump
  if(!ai.onGround&&ai.doubleJumpAvail&&ty<cy-60&&Math.random()<0.06){
    ai.vy=JUMP_V*0.85;ai.doubleJumpAvail=false;
  }
}

// ============================================================
// PHYSICS
// ============================================================
function physicsPlayer(pl){
  if(pl.stunTimer>0)pl.stunTimer--;
  if(pl.attackTimer>0)pl.attackTimer--;
  if(pl.attackCooldown>0)pl.attackCooldown--;
  if(pl.hurtTimer>0)pl.hurtTimer--;
  if(pl.skillCooldown>0)pl.skillCooldown--;
  if(pl.skillActive>0)pl.skillActive--;

  // gravity
  pl.vy+=curGravity;
  pl.x+=pl.vx;
  pl.y+=pl.vy;

  // clamp x
  pl.x=Math.max(-pl.w*0.5,Math.min(GW-pl.w*0.5,pl.x));

  pl.onGround=false;
  const allPlats=[...platforms,...moveBlocks];
  for(const pl2 of allPlats){
    const inX=pl.x+pl.w>pl2.x+4&&pl.x<pl2.x+pl2.w-4;
    const wasAbove=pl.y+pl.h-pl.vy<=pl2.y+4;
    const nowIn=pl.y+pl.h>=pl2.y&&pl.y<pl2.y+pl2.h;
    if(inX&&wasAbove&&nowIn&&pl.vy>=0){
      if(pl2.t==='lava'){
        // take damage
        hitPlayer(pl,{x:pl2.x,y:pl2.y,w:0,h:0,vx:0,vy:0},3,0,'#f60');
        pl.vy=-4;
      } else if(pl2.t==='ice'){
        pl.y=pl2.y-pl.h;pl.vy=0;pl.onGround=true;pl.vx*=0.98;// slippery
      } else if(pl2.t==='bounce'){
        pl.vy=JUMP_V*1.2;pl.doubleJumpAvail=true;
        spawnParticles(pl.x+pl.w/2,pl.y+pl.h,'#f0f',8);
      } else {
        pl.y=pl2.y-pl.h;pl.vy=0;pl.onGround=true;
        if(!pl.dead)pl.vx*=0.78;
      }
    }
    // head bump
    if(inX&&pl.vy<0&&pl.y<=pl2.y+pl2.h&&pl.y+pl.vy>=pl2.y+pl2.h){
      pl.vy=0;
    }
  }

  if(pl.onGround)pl.doubleJumpAvail=true;
  if(!pl.dead)pl.walkPhase+=Math.abs(pl.vx)*0.15;

  // fall off map
  if(pl.y>GH+80&&!pl.dead){
    pl.hp=0;
    killPlayer(pl,pl===p1?p2:p1);
  }
  // dmg nums
  pl.dmgNums=pl.dmgNums.filter(d=>{d.y-=1.5;d.life--;d.alpha=d.life/30;return d.life>0;});
}

function updateMovingBlocks(){
  moveBlocks.forEach(mb=>{
    mb.t+=0.02;
    if(mb.dx!==0){mb.x=mb.ox+Math.sin(mb.t)*mb.range;}
    if(mb.dy!==0){mb.y=mb.oy+Math.sin(mb.t)*mb.range;}
  });
}

function updateBullets(){
  bullets=bullets.filter(b=>{
    b.x+=b.vx;b.y+=b.vy;b.life--;
    if(b.life<=0)return false;
    // hit platforms
    for(const pl of platforms){
      if(b.x>pl.x&&b.x<pl.x+pl.w&&b.y>pl.y&&b.y<pl.y+pl.h){
        spawnParticles(b.x,b.y,b.col,4);
        return false;
      }
    }
    // hit players
    const target=b.owner===p1?p2:p1;
    if(!target.dead){
      const dx=b.x-(target.x+target.w/2),dy=b.y-(target.y+target.h/2);
      if(Math.abs(dx)<target.w&&Math.abs(dy)<target.h/2){
        hitPlayer(target,b.owner,b.dmg,WPN[b.owner.weapon].knock*0.6,b.col);
        spawnParticles(b.x,b.y,b.col,6);
        return false;
      }
    }
    return true;
  });
}

// ============================================================
// PARTICLES
// ============================================================
function spawnParticles(x,y,col,n){
  for(let i=0;i<n;i++){
    particles.push({x,y,vx:(Math.random()-0.5)*7,vy:(Math.random()-2.5)*5,
      life:35+Math.random()*20|0,col,r:2+Math.random()*3});
  }
}
function spawnJumpDust(pl){
  for(let i=0;i<6;i++){
    particles.push({x:pl.x+pl.w/2+(Math.random()-0.5)*20,y:pl.y+pl.h,
      vx:(Math.random()-0.5)*3,vy:-Math.random()*2,
      life:18,col:'#aaa8',r:3+Math.random()*3});
  }
}
function addDmgNum(pl,dmg,col){
  pl.dmgNums.push({x:pl.x+pl.w/2+(Math.random()-0.5)*20,y:pl.y-5,
    text:dmg,col,life:35,alpha:1});
}
function flashScreen(){
  const f=document.getElementById('flash');
  f.style.opacity='0.22';
  setTimeout(()=>f.style.opacity='0',60);
}
function showBanner(txt){
