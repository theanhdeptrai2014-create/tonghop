// INPUT
// ============================================================
function handleInput(){
  if(!running)return;
  // P1
  if(!p1.dead&&!p1.stunTimer){
    if(keys['KeyA']){p1.vx=-SPEED;p1.facing=-1;}
    else if(keys['KeyD']){p1.vx=SPEED;p1.facing=1;}
    else p1.vx*=0.82;
    if(keys['KeyW']){
      if(p1.onGround){p1.vy=JUMP_V;p1.onGround=false;p1.doubleJumpAvail=true;spawnJumpDust(p1);}
      else if(p1.doubleJumpAvail&&!p1.jumpPressed){p1.vy=JUMP_V*0.85;p1.doubleJumpAvail=false;spawnJumpDust(p1);}
      p1.jumpPressed=true;
    } else p1.jumpPressed=false;
    if(keys['KeyS']&&p1.attackCooldown<=0)doAttack(p1,p2);
  }
  // P2
  if(!p2.dead&&!p2.stunTimer){
    if(gameMode===1){
      aiTick(p2,p1);
    } else {
      if(keys['ArrowLeft']){p2.vx=-SPEED;p2.facing=-1;}
      else if(keys['ArrowRight']){p2.vx=SPEED;p2.facing=1;}
      else p2.vx*=0.82;
      if(keys['ArrowUp']){
        if(p2.onGround){p2.vy=JUMP_V;p2.onGround=false;p2.doubleJumpAvail=true;spawnJumpDust(p2);}
        else if(p2.doubleJumpAvail&&!p2.jumpPressed){p2.vy=JUMP_V*0.85;p2.doubleJumpAvail=false;spawnJumpDust(p2);}
        p2.jumpPressed=true;
      } else p2.jumpPressed=false;
      if(keys['ArrowDown']&&p2.attackCooldown<=0)doAttack(p2,p1);
    }
  }
}

// ============================================================
// WEAPONS SYSTEM
// ============================================================
const WPN={
  sword:{cd:22,dmg:18,range:55,knock:5,anim:14,color:'#ffe566',skill:'slash'},
  hammer:{cd:38,dmg:35,range:50,knock:10,anim:20,color:'#a88',skill:'smash'},
  gun:{cd:18,dmg:12,range:999,knock:3,anim:8,color:'#8cf',skill:'burst'},
  shuriken:{cd:15,dmg:10,range:999,knock:2,anim:6,color:'#f8a',skill:'storm'},
  spear:{cd:28,dmg:22,range:72,knock:6,anim:16,color:'#af8',skill:'thrust'},
};

function doAttack(attacker,defender){
  const wt=WPN[attacker.weapon];
  attacker.attackTimer=wt.anim;
  attacker.attackCooldown=wt.cd;
  if(attacker.weapon==='gun'||attacker.weapon==='shuriken'){
    fireBullet(attacker);
  } else {
    // melee
    const dx=(defender.x+defender.w/2)-(attacker.x+attacker.w/2);
    const dy=Math.abs((defender.y+defender.h/2)-(attacker.y+attacker.h/2));
    if(Math.abs(dx)<wt.range&&dy<65){
      hitPlayer(defender,attacker,wt.dmg+(Math.random()*6|0),wt.knock,wt.color);
    }
  }
}

function triggerSkill(attacker,defender){
  if(attacker.skillCooldown>0||attacker.dead)return;
  const wt=WPN[attacker.weapon];
  attacker.skillCooldown=120;
  attacker.skillActive=30;
  attacker.skillType=wt.skill;
  switch(wt.skill){
    case'slash':
      // wide slash
      for(let i=-1;i<=1;i++){
        spawnParticles(attacker.x+attacker.w/2+attacker.facing*40,attacker.y+attacker.h/2+i*20,wt.color,10);
      }
      const dxS=(defender.x+defender.w/2)-(attacker.x+attacker.w/2);
      if(Math.abs(dxS)<90)hitPlayer(defender,attacker,40,8,wt.color);
      break;
    case'smash':
      // ground smash
      attacker.vy=-8;
      spawnParticles(attacker.x+attacker.w/2,attacker.y+attacker.h,'#a88',20);
      const dxH=(defender.x+defender.w/2)-(attacker.x+attacker.w/2);
      if(Math.abs(dxH)<70)hitPlayer(defender,attacker,55,14,'#a88');
      break;
    case'burst':
      // 3 rapid bullets
      for(let i=0;i<3;i++)setTimeout(()=>fireBullet(attacker,true),i*80);
      break;
    case'storm':
      // 8 shurikens in all directions
      for(let a=0;a<8;a++){
        const ang=a/8*Math.PI*2;
        bullets.push({x:attacker.x+attacker.w/2,y:attacker.y+attacker.h/2,
          vx:Math.cos(ang)*9,vy:Math.sin(ang)*9,
          owner:attacker,dmg:15,life:50,col:'#f8a',r:5,skill:true});
      }
      break;
    case'thrust':
      // charge lunge
      attacker.vx=attacker.facing*16;
      attacker.vy=-4;
      spawnParticles(attacker.x+attacker.w/2,attacker.y+attacker.h/2,'#af8',15);
      const dxT=(defender.x+defender.w/2)-(attacker.x+attacker.w/2);
      if(Math.abs(dxT)<100)hitPlayer(defender,attacker,45,12,'#af8');
      break;
  }
}

function fireBullet(pl,skill=false){
  const col=pl.weapon==='gun'?'#8cf':'#f8a';
  const spd=pl.weapon==='gun'?14:10;
  bullets.push({
    x:pl.x+(pl.facing>0?pl.w:0),y:pl.y+pl.h*0.35,
    vx:pl.facing*spd+(pl.vx*0.3),vy:pl.vy*0.2,
    owner:pl,dmg:skill?20:WPN[pl.weapon].dmg,
    life:pl.weapon==='gun'?55:40,
    col,r:pl.weapon==='gun'?4:5,skill
  });
}

function hitPlayer(target,source,dmg,knock,col){
  if(target.dead)return;
  const prev=target.hp;
  target.hp=Math.max(0,target.hp-dmg);
  target.hurtTimer=18;
  target.stunTimer=8;
  const dir=((target.x+target.w/2)-(source.x+source.w/2))>0?1:-1;
  target.vx=dir*knock;
  target.vy=-4;
  spawnParticles(target.x+target.w/2,target.y+20,col,10);
  addDmgNum(target,dmg,col);
  flashScreen();
  if(target.hp<=0&&prev>0)killPlayer(target,source);
}

function killPlayer(target,source){
  target.dead=true;
  spawnParticles(target.x+target.w/2,target.y+target.h/2,target.cfg.col,25);
  if(!roundEnding){
    roundEnding=true;
    const winner=source===p1?'p1':'p2';
    if(winner==='p1')score.p1++;else score.p2++;
    updateHUD();
    showBanner(winner==='p1'?'P1 THẮNG!':'P2 THẮNG!');
    setTimeout(()=>{
      if(score.p1>=3||score.p2>=3)endGame();
      else{round++;initRound();}
    },1600);
  }
}

function endGame(){
  running=false;
  document.getElementById('hud').classList.add('hidden');
  const w=score.p1>=3?'P1':'P2';
  const el=document.getElementById('winnerName');
  el.textContent=w;
  el.style.color=score.p1>=3?p1cfg.col:p2cfg.col;
  document.getElementById('finalScore').textContent=`Tỉ số: ${score.p1} – ${score.p2}`;
  showScreen('gameOverScreen');
}

function updateHUD(){
