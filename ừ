// ============================================================
// DRAWING
// ============================================================
function drawMap(){
  const m=MAPS[curMap];
  ctx.fillStyle=m.bg;ctx.fillRect(0,0,GW,GH);
  // subtle grid
  ctx.strokeStyle='rgba(255,255,255,0.03)';ctx.lineWidth=1;
  for(let x=0;x<GW;x+=40){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,GH);ctx.stroke();}
  for(let y=0;y<GH;y+=40){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(GW,y);ctx.stroke();}
}

function drawPlatforms(){
  const allPlats=[...platforms,...moveBlocks];
  allPlats.forEach(pl=>{
    let top,side,glow;
    switch(pl.t){
      case'ice':   top='#c8f0ff';side='#88ccee';glow='#aaddff33';break;
      case'bounce':top='#ff88ff';side='#cc44cc';glow='#ff00ff33';break;
      case'lava':  top='#ff6600';side='#cc2200';glow='#ff440033';break;
      case'thin':  top='#8aab6a';side='#4a7a3a';glow=null;break;
      default:     top='#4a6a8a';side='#2a4a6a';glow=null;
    }
    // glow effect
    if(glow){ctx.shadowColor=glow;ctx.shadowBlur=12;}
    // top face
    ctx.fillStyle=top;
    ctx.fillRect(pl.x,pl.y,pl.w,8);
    // body
    ctx.fillStyle=side;
    ctx.fillRect(pl.x,pl.y+8,pl.w,pl.h-8);
    // edge highlight
    ctx.fillStyle='rgba(255,255,255,0.18)';
    ctx.fillRect(pl.x,pl.y,pl.w,2);
    ctx.shadowBlur=0;
    // label
    if(pl.t==='ice'){
      ctx.fillStyle='rgba(180,240,255,0.5)';ctx.font='9px Nunito';
      ctx.fillText('❄',pl.x+4,pl.y+16);
    } else if(pl.t==='bounce'){
      ctx.fillStyle='rgba(255,180,255,0.8)';ctx.font='9px Nunito';
      ctx.fillText('↑',pl.x+pl.w/2-4,pl.y+16);
    } else if(pl.t==='lava'){
      ctx.fillStyle='#ff9900';ctx.font='9px sans-serif';
      const lavaT=Date.now()/300;
      for(let lx=pl.x+4;lx<pl.x+pl.w-4;lx+=10){
        const flameH=4+Math.sin(lx*0.3+lavaT)*3;
        ctx.fillRect(lx,pl.y-flameH,3,flameH);
      }
    }
  });
}

function drawParticles(){
  particles=particles.filter(p=>{
    ctx.globalAlpha=p.life/55;
    ctx.fillStyle=p.col;
    ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fill();
    p.x+=p.vx;p.y+=p.vy;p.vy+=0.12;p.r*=0.96;p.life--;
    return p.life>0;
  });
  ctx.globalAlpha=1;
}

function drawBullets(){
  bullets.forEach(b=>{
    ctx.shadowColor=b.col;ctx.shadowBlur=8;
    ctx.fillStyle=b.col;
    ctx.beginPath();ctx.arc(b.x,b.y,b.r,0,Math.PI*2);ctx.fill();
    // trail
    ctx.globalAlpha=0.3;
    ctx.beginPath();ctx.arc(b.x-b.vx*0.8,b.y-b.vy*0.8,b.r*0.6,0,Math.PI*2);ctx.fill();
    ctx.globalAlpha=1;ctx.shadowBlur=0;
  });
}

// ============================================================
// STICKMAN DRAWING
// ============================================================
function drawStickmanAt(cx,x,y,col,acc,wpn,facing,hurt,walkPhase,dead,attackTimer=0,skillActive=0){
  cx.save();
  if(hurt&&(Date.now()/80|0)%2===0){cx.globalAlpha=0.4;}
  const lw=3.5;
  cx.lineCap='round';cx.lineJoin='round';
  const headR=9;
  const bodyLen=26;
  const legLen=22;
  const armLen=18;
  const hx=x,hy=y+headR;
  // shadow
  if(!dead){
    cx.save();cx.globalAlpha=0.18;cx.fillStyle='#000';
    cx.beginPath();cx.ellipse(hx,y+headR*2+bodyLen+legLen+2,16,5,0,0,Math.PI*2);cx.fill();
    cx.restore();
  }

  // accessory (behind head)
  if(acc==='🎩'||acc==='👒'){
    cx.fillStyle=acc==='🎩'?'#222':'#8b4513';
    cx.fillRect(hx-12,hy-headR-14,24,10);
    cx.fillRect(hx-8,hy-headR-22,16,10);
  }
  if(acc==='🪖'){
    cx.fillStyle='#6a7a5a';
    cx.beginPath();cx.arc(hx,hy-headR+2,11,Math.PI,0);cx.fill();
  }
  if(acc==='👑'){
    cx.fillStyle='#ffe566';
    cx.beginPath();cx.moveTo(hx-10,hy-headR+2);
    cx.lineTo(hx-10,hy-headR-10);cx.lineTo(hx-5,hy-headR-6);
    cx.lineTo(hx,hy-headR-13);cx.lineTo(hx+5,hy-headR-6);
    cx.lineTo(hx+10,hy-headR-10);cx.lineTo(hx+10,hy-headR+2);
    cx.fill();
  }

  // head
  cx.beginPath();cx.arc(hx,hy,headR,0,Math.PI*2);
  cx.strokeStyle=col;cx.lineWidth=lw;cx.stroke();
  if(dead){
    // X eyes
    cx.strokeStyle=col;cx.lineWidth=1.5;
    cx.beginPath();cx.moveTo(hx-5,hy-3);cx.lineTo(hx-2,hy);cx.moveTo(hx-2,hy-3);cx.lineTo(hx-5,hy);cx.stroke();
    cx.beginPath();cx.moveTo(hx+2,hy-3);cx.lineTo(hx+5,hy);cx.moveTo(hx+5,hy-3);cx.lineTo(hx+2,hy);cx.stroke();
  } else {
    // eye
    cx.fillStyle=col;
    cx.beginPath();cx.arc(hx+facing*3.5,hy-1,2,0,Math.PI*2);cx.fill();
    // mouth (smile or hurt)
    cx.strokeStyle=col;cx.lineWidth=1.5;
    if(hurt){cx.beginPath();cx.arc(hx,hy+3,4,0.2,Math.PI-0.2,true);cx.stroke();}
    else{cx.beginPath();cx.arc(hx,hy+2,4,0.2,Math.PI-0.2);cx.stroke();}
  }
  // emoji acc
  if(['😈','🌟','❄'].includes(acc)){
    cx.font='16px sans-serif';cx.textAlign='center';
    cx.fillText(acc,hx,hy-headR-4);
  }

  const bodyTop=hy+headR,bodyBot=bodyTop+bodyLen;
  // body
  cx.beginPath();cx.moveTo(hx,bodyTop);cx.lineTo(hx,bodyBot);
  cx.strokeStyle=col;cx.lineWidth=lw;cx.stroke();

  // legs
  const ph=walkPhase;
  const legSwing=dead?20:Math.sin(ph)*14;
  // left leg
  cx.beginPath();cx.moveTo(hx,bodyBot);cx.lineTo(hx-legSwing,bodyBot+legLen);
  cx.strokeStyle=col;cx.lineWidth=lw;cx.stroke();
  // right leg
  cx.beginPath();cx.moveTo(hx,bodyBot);cx.lineTo(hx+legSwing,bodyBot+legLen);
  cx.stroke();

  // arms & weapon
  const armTop=bodyTop+6;
  const armSwing=Math.sin(ph+0.5)*10;
  if(attackTimer>0&&!dead){
    const prog=attackTimer>0?1-attackTimer/WPN[wpn].anim:0;
    const reach=facing*(armLen+20)*Math.sin(prog*Math.PI+0.2);
    const lift=-10*Math.sin(prog*Math.PI);
    // arm
    cx.beginPath();cx.moveTo(hx,armTop);cx.lineTo(hx+reach,armTop+lift+8);
    cx.strokeStyle=col;cx.lineWidth=lw;cx.stroke();
    // weapon glow
    cx.shadowColor=WPN[wpn].color;cx.shadowBlur=12;
    drawWeapon(cx,wpn,hx+reach,armTop+lift+8,facing,WPN[wpn].color,1);
    cx.shadowBlur=0;
    // back arm
    cx.beginPath();cx.moveTo(hx,armTop+4);cx.lineTo(hx-facing*10,armTop+14);
    cx.strokeStyle=col;cx.lineWidth=lw;cx.stroke();
  } else {
    // idle/walk arms
    cx.beginPath();cx.moveTo(hx,armTop);cx.lineTo(hx+facing*10+armSwing,armTop+armLen);
    cx.strokeStyle=col;cx.lineWidth=lw;cx.stroke();
    cx.beginPath();cx.moveTo(hx,armTop);cx.lineTo(hx+facing*8-armSwing,armTop+armLen-4);
    cx.stroke();
    // idle weapon
    drawWeapon(cx,wpn,hx+facing*10+armSwing,armTop+armLen,facing,WPN[wpn].color,0.6);
  }
  // skill aura
  if(skillActive>0){
    cx.globalAlpha=skillActive/30*0.5;
    cx.strokeStyle=WPN[wpn].color;cx.lineWidth=3;
    cx.beginPath();cx.arc(hx,hy+bodyLen/2,30,0,Math.PI*2);cx.stroke();
    cx.globalAlpha=1;
  }
  cx.restore();
}

function drawWeapon(cx,wpn,wx,wy,facing,col,alpha){
  cx.save();cx.globalAlpha=alpha;cx.strokeStyle=col;cx.fillStyle=col;
  switch(wpn){
    case'sword':
      cx.lineWidth=2.5;
      cx.beginPath();cx.moveTo(wx,wy);cx.lineTo(wx+facing*24,wy-12);cx.stroke();
      cx.beginPath();cx.moveTo(wx+facing*8,wy-4);cx.lineTo(wx+facing*16,wy-14);
      cx.lineTo(wx+facing*20,wy-10);cx.stroke();
      break;
    case'hammer':
      cx.lineWidth=2;
      cx.beginPath();cx.moveTo(wx,wy);cx.lineTo(wx+facing*18,wy-8);cx.stroke();
      cx.fillRect(wx+facing*14,wy-18,facing*12,16);
      break;
    case'gun':
      cx.lineWidth=2;
      cx.beginPath();cx.moveTo(wx,wy);cx.lineTo(wx+facing*20,wy-2);cx.stroke();
      cx.fillRect(wx+facing*4,wy-6,facing*10,6);
      break;
    case'shuriken':
      cx.lineWidth=1.5;
      for(let i=0;i<4;i++){
        const a=i*Math.PI/2+(Date.now()/200);
        cx.beginPath();cx.moveTo(wx,wy);
        cx.lineTo(wx+Math.cos(a)*10,wy+Math.sin(a)*10);cx.stroke();
      }
      break;
    case'spear':
      cx.lineWidth=2;
      cx.beginPath();cx.moveTo(wx,wy);cx.lineTo(wx+facing*32,wy-6);cx.stroke();
      cx.beginPath();cx.moveTo(wx+facing*28,wy-10);cx.lineTo(wx+facing*38,wy-6);
      cx.lineTo(wx+facing*28,wy-2);cx.fill();
      break;
  }
  cx.restore();
}

function drawPlayer(pl){
  drawStickmanAt(ctx,
    pl.x+pl.w/2,pl.y,
    pl.cfg.col,pl.cfg.acc,pl.weapon,
    pl.facing,pl.hurtTimer>0,pl.walkPhase,
    pl.dead,pl.attackTimer,pl.skillActive);
  // skill cooldown indicator
  if(pl.skillCooldown>0&&!pl.dead){
    const cd=pl.skillCooldown/120;
    ctx.strokeStyle=WPN[pl.weapon].color;ctx.lineWidth=2;ctx.globalAlpha=0.5;
    ctx.beginPath();ctx.arc(pl.x+pl.w/2,pl.y-18,10,
      -Math.PI/2,-Math.PI/2+2*Math.PI*(1-cd));ctx.stroke();
    ctx.globalAlpha=1;
  }
  // dmg numbers
  pl.dmgNums.forEach(d=>{
    ctx.globalAlpha=d.alpha;
    ctx.fillStyle=d.col;ctx.font='bold 14px Bangers';ctx.textAlign='center';
    ctx.fillText(d.text,d.x,d.y);
  });
  ctx.globalAlpha=1;ctx.textAlign='left';
}

// ============================================================
// MAIN LOOP
// ============================================================
function loop(){
  if(!running)return;
  handleInput();
  if(!roundEnding){
    physicsPlayer(p1);
    physicsPlayer(p2);
  } else {
    physicsPlayer(p1);
    physicsPlayer(p2);
  }
  updateMovingBlocks();
  updateBullets();
  // --- DRAW ---
  drawMap();
  drawPlatforms();
  drawParticles();
  drawBullets();
  drawPlayer(p1);
  drawPlayer(p2);
  // controls hint
  ctx.fillStyle='rgba(255,255,255,0.15)';ctx.font='10px Nunito';
  if(gameMode===1)ctx.fillText('WASD: di chuyển/nhảy/đánh  |  SS: chiêu đặc biệt',8,GH-6);
  else ctx.fillText('P1: WASD  SS=chiêu  |  P2: ←→↑↓  ↓↓=chiêu',8,GH-6);
  animId=requestAnimationFrame(loop);
  prevKeys={...keys};
}
// ============================================================
// INIT
// ============================================================
showScreen('menuScreen');
</script>
