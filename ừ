// ============================================================
// INIT ROUND
// ============================================================
let curGravity=0.6;
function initRound(){
  roundEnding=false;roundEndTimer=0;
  const m=MAPS[curMap];
  curGravity=m.gravity||0.6;
  bullets=[];particles=[];
  // parse platforms
  platforms=m.plats.map(pl=>({
    x:pl.x/100*GW,y:pl.y/100*GH,
    w:pl.w/100*GW,h:Math.max(6,pl.h/100*GH),
    t:pl.t||'solid'
  }));
  // spikes
  platforms.push(...(m.spikes||[]).map(sp=>({
    x:sp.x/100*GW,y:sp.y/100*GH,
    w:sp.w/100*GW,h:10,t:'lava'
  })));
  // moving blocks
  moveBlocks=(m.movb||[]).map(mb=>({
    ox:mb.x/100*GW,oy:mb.y/100*GH,
    x:mb.x/100*GW,y:mb.y/100*GH,
    w:mb.w/100*GW,h:Math.max(6,mb.h/100*GH),
    dx:mb.dx*0.8,dy:mb.dy*0.8,
    range:mb.range/100*GW,
    t:0,type:'solid'
  }));
  // spawn positions — find a good platform
  const ground=platforms.find(pl=>pl.y>GH*0.8&&pl.w>GW*0.3)||platforms[0];
  const spawnY=ground.y-60;
  p1=makePlayer(ground.x+40,spawnY,p1cfg,1,false);
  p2=makePlayer(ground.x+ground.w-60,spawnY,p2cfg,-1,true);
  updateHUD();
}

