<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Supreme Duelist</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Bangers&family=Nunito:wght@400;700;900&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
body{background:#0d0d1a;overflow:hidden;font-family:'Nunito',sans-serif;user-select:none}
canvas{display:block}
#ui{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none}
#ui>*{pointer-events:all}

/* ===== SCREENS ===== */
.screen{position:fixed;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#0d0d1a;z-index:100;gap:0}
.screen.hidden{display:none}

/* MENU */
#menu-bg{position:absolute;inset:0;overflow:hidden}
.star{position:absolute;border-radius:50%;background:#fff;animation:twinkle 3s infinite}
@keyframes twinkle{0%,100%{opacity:.2}50%{opacity:.9}}
#logo-wrap{position:relative;z-index:2;text-align:center;margin-bottom:24px}
.logo-title{font-family:'Bangers',cursive;font-size:52px;letter-spacing:4px;color:#ffe566;text-shadow:0 0 20px #ff9900aa,4px 4px 0 #c00,6px 6px 0 #800;line-height:1}
.logo-sub{font-size:13px;color:#aaa;letter-spacing:6px;text-transform:uppercase;margin-top:4px}

.menu-btn{background:linear-gradient(135deg,#222,#333);border:2px solid #ffe566;color:#ffe566;font-family:'Bangers',cursive;font-size:22px;letter-spacing:2px;padding:12px 36px;border-radius:8px;cursor:pointer;transition:all .15s;position:relative;z-index:2;min-width:220px;text-align:center}
.menu-btn:hover{background:linear-gradient(135deg,#ffe566,#ff9900);color:#000;transform:scale(1.05);box-shadow:0 0 20px #ffe56688}
.menu-btn.blue{border-color:#4af;color:#4af}
.menu-btn.blue:hover{background:linear-gradient(135deg,#4af,#06f);color:#fff}
.menu-btn.red{border-color:#f64;color:#f64}
.menu-btn.red:hover{background:linear-gradient(135deg,#f64,#c00);color:#fff}
.menu-btn.green{border-color:#4f8;color:#4f8}
.menu-btn.green:hover{background:linear-gradient(135deg,#4f8,#080);color:#000}
.menu-gap{height:10px}

/* HUD */
#hud{position:fixed;top:0;left:0;right:0;padding:8px 12px;display:flex;justify-content:space-between;align-items:flex-start;z-index:50;pointer-events:none}
.hud-side{width:38%}
.hud-name{font-family:'Bangers',cursive;font-size:16px;letter-spacing:1px;margin-bottom:3px}
.hud-hp-bg{height:10px;background:#333;border-radius:5px;overflow:hidden;border:1px solid #555}
.hud-hp-fill{height:100%;border-radius:5px;transition:width .1s}
.hud-hp-fill.p1{background:linear-gradient(90deg,#f44,#f84)}
.hud-hp-fill.p2{background:linear-gradient(90deg,#48f,#4af)}
.hud-weapon{font-size:11px;margin-top:2px;opacity:.8}
.hud-center{text-align:center;min-width:80px}
.hud-score{font-family:'Bangers',cursive;font-size:28px;color:#ffe566;text-shadow:0 0 10px #ff9900}
.hud-round{font-size:11px;color:#888;margin-top:-2px}
.hud-timer{font-family:'Bangers',cursive;font-size:18px;color:#fff}

/* CUSTOMIZATION */
#custom-screen{overflow-y:auto}
.custom-title{font-family:'Bangers',cursive;font-size:36px;color:#ffe566;text-shadow:3px 3px 0 #c00;letter-spacing:3px;margin-bottom:16px}
.custom-body{display:flex;gap:20px;width:100%;max-width:700px;padding:0 16px}
.custom-panel{flex:1;background:#1a1a2e;border:1px solid #333;border-radius:12px;padding:14px}
.custom-panel h3{font-family:'Bangers',cursive;font-size:20px;letter-spacing:2px;margin-bottom:12px}
.custom-panel.p1 h3{color:#f64}
.custom-panel.p2 h3{color:#4af}
.preview-wrap{display:flex;justify-content:center;margin-bottom:12px}
.custom-row{margin-bottom:10px}
.custom-label{font-size:11px;color:#888;margin-bottom:4px;text-transform:uppercase;letter-spacing:1px}
.color-grid{display:flex;flex-wrap:wrap;gap:4px}
.color-swatch{width:24px;height:24px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:transform .1s}
.color-swatch:hover,.color-swatch.active{border-color:#fff;transform:scale(1.2)}
.acc-grid{display:flex;flex-wrap:wrap;gap:4px}
.acc-btn{background:#222;border:1px solid #444;color:#ccc;font-size:11px;padding:4px 8px;border-radius:6px;cursor:pointer;transition:all .1s}
.acc-btn:hover,.acc-btn.active{border-color:#ffe566;color:#ffe566;background:#2a2a1a}

/* MAP SELECT */
.map-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;padding:0 12px;max-width:600px;overflow-y:auto;max-height:55vh}
.map-card{background:#1a1a2e;border:2px solid #333;border-radius:8px;padding:8px 4px;cursor:pointer;text-align:center;transition:all .15s}
.map-card:hover,.map-card.active{border-color:#ffe566;background:#22220a}
.map-card canvas{display:block;margin:0 auto 4px}
.map-card span{font-size:10px;color:#aaa;display:block}
.map-actions{display:flex;gap:12px;margin-top:14px}

/* GAME OVER */
.winner-name{font-family:'Bangers',cursive;font-size:64px;letter-spacing:4px;text-shadow:4px 4px 0 #000,0 0 40px currentColor}
.ko-text{font-family:'Bangers',cursive;font-size:28px;color:#fff;letter-spacing:3px;opacity:.7;margin-top:-8px}
.final-score{font-size:18px;color:#aaa;margin:10px 0 20px}

/* FLASH */
#flash{position:fixed;inset:0;background:#fff;opacity:0;pointer-events:none;z-index:200;transition:opacity .05s}
#round-banner{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Bangers',cursive;font-size:48px;color:#ffe566;text-shadow:3px 3px 0 #000,0 0 30px #ff9900;letter-spacing:4px;z-index:150;opacity:0;pointer-events:none;text-align:center;white-space:nowrap}
</style>
</head>
<body>

<!-- CANVAS -->
<canvas id="c"></canvas>
<div id="ui">
  <!-- HUD -->
  <div id="hud" class="hidden">
    <div class="hud-side" id="p1hud">
      <div class="hud-name" style="color:#f64" id="p1name">P1</div>
