<!-- FLASH / BANNER -->
<div id="flash"></div>
<div id="round-banner" id="roundBanner"></div>

<!-- ===== MENU ===== -->
<div class="screen" id="menuScreen">
  <div id="menu-bg"></div>
  <div id="logo-wrap">
    <div class="logo-title">SUPREME<br>DUELIST</div>
    <div class="logo-sub">Stickman Fighting</div>
  </div>
  <button class="menu-btn" onclick="showCustom(1)" style="margin-bottom:8px">⚔ 1 Người Chơi</button>
  <button class="menu-btn blue" onclick="showCustom(2)" style="margin-bottom:8px">⚔ 2 Người Chơi</button>
  <button class="menu-btn green" onclick="showMapSelect()" style="margin-bottom:8px">🗺 Chọn Map</button>
</div>

<!-- ===== CUSTOMIZE ===== -->
<div class="screen hidden" id="customScreen">
  <div class="custom-title">TÙY CHỈNH NHÂN VẬT</div>
  <div class="custom-body">
    <div class="custom-panel p1" id="customP1">
      <h3>NGƯỜI CHƠI 1</h3>
      <div class="preview-wrap"><canvas id="prevC1" width="60" height="100"></canvas></div>
      <div class="custom-row">
        <div class="custom-label">Màu nhân vật</div>
        <div class="color-grid" id="colorsP1"></div>
      </div>
      <div class="custom-row">
        <div class="custom-label">Phụ kiện đầu</div>
        <div class="acc-grid" id="accP1"></div>
      </div>
      <div class="custom-row">
        <div class="custom-label">Vũ khí</div>
        <div class="acc-grid" id="wpnP1"></div>
      </div>
    </div>
    <div class="custom-panel p2" id="customP2">
      <h3 id="p2CustomTitle">NGƯỜI CHƠI 2</h3>
      <div class="preview-wrap"><canvas id="prevC2" width="60" height="100"></canvas></div>
      <div class="custom-row">
        <div class="custom-label">Màu nhân vật</div>
        <div class="color-grid" id="colorsP2"></div>
      </div>
      <div class="custom-row">
        <div class="custom-label">Phụ kiện đầu</div>
        <div class="acc-grid" id="accP2"></div>
      </div>
      <div class="custom-row">
        <div class="custom-label">Vũ khí</div>
        <div class="acc-grid" id="wpnP2"></div>
      </div>
    </div>
  </div>
  <div style="display:flex;gap:12px;margin-top:16px">
    <button class="menu-btn" onclick="startGame()">▶ BẮT ĐẦU</button>
    <button class="menu-btn red" onclick="showScreen('menuScreen')">✕ Quay lại</button>
  </div>
</div>

<!-- ===== MAP SELECT ===== -->
<div class="screen hidden" id="mapScreen">
  <div class="custom-title">CHỌN MAP</div>
  <div class="map-grid" id="mapGrid"></div>
  <div class="map-actions">
    <button class="menu-btn green" onclick="randomMap()">🎲 Ngẫu nhiên</button>
    <button class="menu-btn" onclick="showScreen('menuScreen')">✕ Quay lại</button>
  </div>
</div>

<!-- ===== GAME OVER ===== -->
<div class="screen hidden" id="gameOverScreen">
  <div class="winner-name" id="winnerName">P1</div>
  <div class="ko-text">CHIẾN THẮNG!</div>
  <div class="final-score" id="finalScore">3 – 1</div>
  <button class="menu-btn" onclick="restartRound()" style="margin-bottom:8px">🔄 Chơi lại</button>
  <button class="menu-btn red" onclick="showScreen('menuScreen')">🏠 Menu</button>
</div>

<script>
// ============================================================
// CONFIG
// ============================================================
const GW=800,GH=480;
const GRAV=0.6,JUMP_V=-14,SPEED=4.2,MAX_HP=150;
const COLORS=['#f55','#f84','#fc0','#4f4','#4af','#88f','#f4f','#fff','#aaa','#f06','#0ff','#fa0'];
const ACCS=['none','👑','🎩','🪖','😈','👒','🌟','❄'];
const WEAPONS=['sword','hammer','gun','shuriken','spear'];
const WPN_NAMES={'sword':'⚔ Kiếm','hammer':'🔨 Búa','gun':'🔫 Súng','shuriken':'✦ Phi tiêu','spear':'🗡 Giáo'};

// ============================================================
// STATE
// ============================================================
let canvas,ctx,W,H,scale=1;
let gameMode=1,running=false,paused=false;
let p1cfg={col:'#f55',acc:'none',wpn:'sword'};
let p2cfg={col:'#4af',acc:'none',wpn:'sword'};
let score={p1:0,p2:0};
let curMap=0,round=1;
let p1,p2,bullets,particles,platforms,moveBlocks;
let roundEnding=false,roundEndTimer=0;
let keys={},prevKeys={};
let animId;

// ============================================================
// MAPS (30 maps)
// ============================================================
const MAPS=[];
function defMap(name,bg,plats,spikes,movb,gravity){
  MAPS.push({name,bg,plats,spikes:spikes||[],movb:movb||[],gravity:gravity||0.6});
}
// plat: [x%,y%,w%,h%,type]  type: solid/ice/bounce/lava
const S='solid',IC='ice',BO='bounce',LA='lava',TH='thin';
function p(x,y,w,h,t='solid'){return{x,y,w,h,t}}
function sp(x,y,w){return{x,y,w,h:8,t:'lava'}}
function mb(x,y,w,h,dx,dy,range){return{x,y,w,h,dx,dy,range,ox:x,oy:y,t:0,type:'solid'}}

defMap('Arena'     ,'#1a1a2e',[p(0,90,100,10),p(15,65,20,3),p(65,65,20,3),p(40,48,20,3)])
defMap('Sky High'  ,'#0a1520',[p(0,95,30,5),p(70,95,30,5),p(20,72,25,3),p(55,72,25,3),p(38,52,24,3),p(38,85,24,3)])
defMap('Cave'      ,'#080810',[p(0,90,100,10),p(0,0,5,100),p(95,0,5,100),p(20,60,60,3),p(10,40,30,3),p(60,40,30,3)])
defMap('Ice World' ,'#d0eeff',[p(0,90,100,10,IC),p(20,70,20,3,IC),p(60,70,20,3,IC),p(40,50,20,3,IC)])
defMap('Lava Pit'  ,'#1a0800',[p(0,90,40,10),p(60,90,40,10),p(20,65,20,3),p(60,65,20,3),p(40,45,20,3)],[sp(40,88,20)])
defMap('Platforms' ,'#0d1a0d',[p(0,95,15,5),p(20,80,15,3),p(40,68,15,3),p(60,80,15,3),p(85,95,15,5),p(35,55,30,3)])
defMap('Bounce!'   ,'#1a001a',[p(0,90,100,10),p(15,68,20,3,BO),p(65,68,20,3,BO),p(40,50,20,3,BO)])
defMap('Spiral'    ,'#0a0a0a',[p(0,95,100,5),p(5,75,25,3),p(30,60,20,3),p(55,48,20,3),p(75,35,20,3)])
defMap('Tower'     ,'#100018',[p(35,92,30,8),p(30,75,15,3),p(55,75,15,3),p(35,60,30,3),p(38,45,24,3),p(40,30,20,3)])
defMap('Bridge'    ,'#001020',[p(0,90,35,5),p(65,90,35,5),p(30,90,40,3,TH),p(20,65,25,3),p(55,65,25,3)])
defMap('Moving'    ,'#0a1a00',[p(0,92,20,8),p(80,92,20,8)],[],[mb(30,70,20,5,1.5,0,25),mb(50,52,20,5,-1.2,0,20)])
defMap('Dual Tower','#0d0010',[p(5,92,22,8),p(73,92,22,8),p(5,72,22,3),p(73,72,22,3),p(5,52,22,3),p(73,52,22,3),p(38,80,24,3)])
defMap('Temple'    ,'#1a1000',[p(0,92,100,8),p(15,72,18,3),p(35,60,15,3),p(50,60,15,3),p(68,72,18,3),p(40,45,20,3),p(0,0,8,50),p(92,0,8,50)])
defMap('Space'     ,'#000008',[p(0,95,30,5),p(70,95,30,5),p(25,75,20,3),p(55,75,20,3),p(40,58,20,3),p(10,55,15,3),p(75,55,15,3)],[],[mb(37,42,26,4,0,-1.0,15)])
defMap('Zigzag'    ,'#0a0a1a',[p(0,92,25,8),p(20,75,20,3),p(45,62,20,3),p(65,75,20,3),p(75,92,25,8),p(38,50,24,3)])
defMap('Colosseum' ,'#1a0a00',[p(0,92,100,8),p(0,0,5,80),p(95,0,5,80),p(20,65,20,3),p(60,65,20,3),p(40,48,20,3),p(0,35,20,3),p(80,35,20,3)])
defMap('Desert'    ,'#1a1000',[p(0,90,100,10),p(10,68,18,3),p(35,58,12,3),p(55,68,18,3),p(80,58,12,3)])
defMap('Jungle'    ,'#001a00',[p(0,92,100,8),p(5,72,15,3,TH),p(25,62,12,3,TH),p(45,52,12,3,TH),p(65,62,12,3,TH),p(82,72,15,3,TH),p(35,42,30,3)])
defMap('Volcano'   ,'#1a0500',[p(0,90,40,10),p(60,90,40,10),p(15,68,20,3),p(65,68,20,3),p(38,52,24,3)],[sp(38,88,24),sp(0,88,15),sp(85,88,15)])
defMap('Rooftop'   ,'#05101a',[p(0,90,100,10),p(20,72,20,5),p(60,72,20,5),p(40,56,20,4),p(5,60,10,40),p(85,60,10,40)])
defMap('Maze'      ,'#080808',[p(0,92,100,8),p(0,0,3,60),p(97,0,3,60),p(20,50,3,42),p(77,50,3,42),p(40,68,20,3),p(30,45,20,3),p(50,30,20,3)])
defMap('Floating'  ,'#000a1a',[p(5,88,12,4),p(22,78,12,4),p(39,68,12,4),p(56,78,12,4),p(73,88,12,4),p(30,55,15,4),p(55,55,15,4),p(42,42,16,4)])
defMap('Waterfall' ,'#001520',[p(0,92,15,8),p(85,92,15,8),p(0,0,12,92),p(88,0,12,92),p(30,72,40,4),p(35,52,30,4)])
defMap('Low Grav'  ,'#000020',[p(0,92,100,8),p(15,72,20,3),p(65,72,20,3),p(40,55,20,3),p(10,45,15,3),p(75,45,15,3)],[],[],0.25)
defMap('Spike Run' ,'#1a0000',[p(0,90,100,10),p(20,68,18,3),p(62,68,18,3),p(40,50,20,3)],[sp(30,88,8),sp(48,88,8),sp(62,88,8)])
defMap('Sky Battle','#001530',[p(0,88,20,4),p(80,88,20,4),p(30,75,18,3),p(52,75,18,3),p(20,60,20,3),p(60,60,20,3),p(38,45,24,3)])
defMap('Dungeon'   ,'#0a0500',[p(0,92,100,8),p(0,0,4,92),p(96,0,4,92),p(0,60,30,4),p(70,60,30,4),p(35,45,30,4)])
defMap('Canyon'    ,'#1a0800',[p(0,92,30,8),p(70,92,30,8),p(25,72,20,3),p(55,72,20,3),p(40,55,20,3),p(10,58,12,3),p(78,58,12,3)])
defMap('Final Boss','#0a000f',[p(0,92,100,8),p(5,70,20,3),p(75,70,20,3),p(35,55,30,4),p(20,38,20,3),p(60,38,20,3),p(40,25,20,3)],[],[mb(30,80,15,4,1,0,18),mb(55,80,15,4,-1,0,18)])
defMap('Classic'   ,'#111122',[p(0,88,100,12),p(18,65,18,4),p(64,65,18,4),p(38,48,24,4),p(5,50,12,4),p(83,50,12,4)])

// ============================================================
// INIT
// ============================================================
window.addEventListener('load',()=>{
  canvas=document.getElementById('c');
  ctx=canvas.getContext('2d');
  resizeCanvas();
  window.addEventListener('resize',resizeCanvas);
  buildStars();
  buildMapGrid();
  buildCustomUI();
  document.addEventListener('keydown',e=>{
    const c=e.code;
    if(!prevKeys[c]){
      // double-tap S or ArrowDown for skill
      if(c==='KeyS')checkDoubleTap('s1');
      if(c==='ArrowDown')checkDoubleTap('s2');
    }
    keys[c]=true;
    if(['ArrowUp','ArrowDown','ArrowLeft','ArrowRight','Space'].includes(c))e.preventDefault();
  });
  document.addEventListener('keyup',e=>{keys[e.code]=false;});
});

function resizeCanvas(){
  const vw=window.innerWidth,vh=window.innerHeight;
  scale=Math.min(vw/GW,vh/GH);
  W=GW;H=GH;
  canvas.width=W;canvas.height=H;
  canvas.style.width=(W*scale)+'px';
  canvas.style.height=(H*scale)+'px';
  canvas.style.position='fixed';
  canvas.style.left=((vw-W*scale)/2)+'px';
  canvas.style.top=((vh-H*scale)/2)+'px';
}

// ============================================================
// UI HELPERS
// ============================================================
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.add('hidden'));
  document.getElementById(id).classList.remove('hidden');
}
function buildStars(){
  const bg=document.getElementById('menu-bg');
  for(let i=0;i<80;i++){
    const s=document.createElement('div');
    s.className='star';
    const sz=Math.random()*3+1;
    s.style.cssText=`width:${sz}px;height:${sz}px;top:${Math.random()*100}%;left:${Math.random()*100}%;animation-delay:${Math.random()*3}s;animation-duration:${2+Math.random()*3}s`;
    bg.appendChild(s);
  }
}

function buildCustomUI(){
  function buildSide(pid,cfg){
    const cg=document.getElementById('colors'+pid);
    cg.innerHTML='';
    COLORS.forEach(c=>{
      const sw=document.createElement('div');
      sw.className='color-swatch'+(cfg.col===c?' active':'');
      sw.style.background=c;
      sw.onclick=()=>{cfg.col=c;cg.querySelectorAll('.color-swatch').forEach(x=>x.classList.remove('active'));sw.classList.add('active');drawPreview(pid,cfg);};
      cg.appendChild(sw);
    });
    const ag=document.getElementById('acc'+pid);
    ag.innerHTML='';
    ACCS.forEach(a=>{
      const b=document.createElement('button');
      b.className='acc-btn'+(cfg.acc===a?' active':'');
      b.textContent=a==='none'?'없음':a;
      b.onclick=()=>{cfg.acc=a;ag.querySelectorAll('.acc-btn').forEach(x=>x.classList.remove('active'));b.classList.add('active');drawPreview(pid,cfg);};
      ag.appendChild(b);
    });
    const wg=document.getElementById('wpn'+pid);
    wg.innerHTML='';
    WEAPONS.forEach(w=>{
      const b=document.createElement('button');
      b.className='acc-btn'+(cfg.wpn===w?' active':'');
      b.textContent=WPN_NAMES[w];
      b.onclick=()=>{cfg.wpn=w;wg.querySelectorAll('.acc-btn').forEach(x=>x.classList.remove('active'));b.classList.add('active');drawPreview(pid,cfg);};
      wg.appendChild(b);
    });
    drawPreview(pid,cfg);
  }
  buildSide('P1',p1cfg);
  buildSide('P2',p2cfg);
}

